{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/AtlasHorizonNet/LANtern"
        },
        {
          "url": "https://github.com/AtlasHorizonNet/LANtern/*"
        }
      ]
    }
  ]
}
